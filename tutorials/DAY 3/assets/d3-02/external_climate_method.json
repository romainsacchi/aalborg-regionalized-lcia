{
  "name": "External-function climate method for D3-02",
  "unit": "kg CO2-eq",
  "version": "1.0",
  "description": "External-function teaching GWP100 characterization factors for fossil carbon dioxide, fossil and biogenic methane, and dinitrogen monoxide. Methane and N2O are reevaluated by the notebook-level gwp_concentration_dependent function, while fossil carbon dioxide stays fixed at 1. Exact flow names avoid accidental matches.",
  "strategies": [
    "map_exchanges"
  ],
  "exchanges": [
    {
      "supplier": {
        "name": "Carbon dioxide, fossil",
        "operator": "equals",
        "matrix": "biosphere"
      },
      "consumer": {
        "matrix": "technosphere"
      },
      "value": 1.0
    },
    {
      "supplier": {
        "name": "Methane, fossil",
        "operator": "equals",
        "matrix": "biosphere"
      },
      "consumer": {
        "matrix": "technosphere"
      },
      "value": "gwp_concentration_dependent('CH4', horizon_years, ch4_concentration_ppb)"
    },
    {
      "supplier": {
        "name": "Methane, non-fossil",
        "operator": "equals",
        "matrix": "biosphere"
      },
      "consumer": {
        "matrix": "technosphere"
      },
      "value": "gwp_concentration_dependent('CH4', horizon_years, ch4_concentration_ppb)"
    },
    {
      "supplier": {
        "name": "Methane, from soil or biomass stock",
        "operator": "equals",
        "matrix": "biosphere"
      },
      "consumer": {
        "matrix": "technosphere"
      },
      "value": "gwp_concentration_dependent('CH4', horizon_years, ch4_concentration_ppb)"
    },
    {
      "supplier": {
        "name": "Dinitrogen monoxide",
        "operator": "equals",
        "matrix": "biosphere"
      },
      "consumer": {
        "matrix": "technosphere"
      },
      "value": "gwp_concentration_dependent('N2O', horizon_years, n2o_concentration_ppb)"
    }
  ]
}
