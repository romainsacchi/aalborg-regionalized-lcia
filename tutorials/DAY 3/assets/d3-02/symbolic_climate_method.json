{
  "name": "Symbolic climate method for D3-02",
  "unit": "kg CO2-eq",
  "version": "1.0",
  "description": "Symbolic teaching GWP100 characterization factors for fossil carbon dioxide, fossil and biogenic methane, and dinitrogen monoxide. Methane and N2O keep only the concentration-dependent 1/sqrt(C) term, while fossil carbon dioxide stays fixed at 1. Exact flow names avoid accidental matches.",
  "strategies": [
    "map_exchanges"
  ],
  "exchanges": [
    {
      "supplier": {
        "name": "Carbon dioxide, fossil",
        "operator": "equals",
        "matrix": "biosphere"
      },
      "consumer": {
        "matrix": "technosphere"
      },
      "value": 1.0
    },
    {
      "supplier": {
        "name": "Methane, fossil",
        "operator": "equals",
        "matrix": "biosphere"
      },
      "consumer": {
        "matrix": "technosphere"
      },
      "value": "ch4_gwp100_reference * sqrt(ch4_reference_ppb / ch4_concentration_ppb)"
    },
    {
      "supplier": {
        "name": "Methane, non-fossil",
        "operator": "equals",
        "matrix": "biosphere"
      },
      "consumer": {
        "matrix": "technosphere"
      },
      "value": "ch4_gwp100_reference * sqrt(ch4_reference_ppb / ch4_concentration_ppb)"
    },
    {
      "supplier": {
        "name": "Methane, from soil or biomass stock",
        "operator": "equals",
        "matrix": "biosphere"
      },
      "consumer": {
        "matrix": "technosphere"
      },
      "value": "ch4_gwp100_reference * sqrt(ch4_reference_ppb / ch4_concentration_ppb)"
    },
    {
      "supplier": {
        "name": "Dinitrogen monoxide",
        "operator": "equals",
        "matrix": "biosphere"
      },
      "consumer": {
        "matrix": "technosphere"
      },
      "value": "n2o_gwp100_reference * sqrt(n2o_reference_ppb / n2o_concentration_ppb)"
    }
  ]
}
